{
  "project": "RadarTariffe",
  "defaultUserAgent": "RadarTariffeBot/0.1 (+https://tuodominio.it; contact: info@tuodominio.it)",
  "sources": [
    {
      "id": "demo-mobile-offer",
      "enabled": false,
      "sector": "mobile",
      "provider": "Operatore Demo",
      "name": "Offerta Mobile Demo",
      "url": "https://example.com/offerta-mobile",
      "respectRobotsTxt": true,
      "politeDelaySeconds": 3,
      "rules": {
        "price_regex": "([0-9]+,[0-9]{2})\\s*€\\s*/?mese",
        "expiry_regex": "(?:fino al|valida fino al)\\s*([0-9]{2}/[0-9]{2}/[0-9]{4})",
        "activation_regex": "attivazione[^0-9]*([0-9]+,[0-9]{2})\\s*€"
      },
      "manualDefaults": {
        "type": "monthly",
        "promoMonths": 12,
        "constraintMonths": 0,
        "confidence": 60,
        "tags": ["imported", "review-required"]
      }
    },
    {
      "id": "demo-css-selector",
      "enabled": false,
      "sector": "fibra",
      "provider": "Provider Demo",
      "name": "Fibra Demo",
      "url": "https://example.com/fibra",
      "respectRobotsTxt": true,
      "rules": {
        "price_selector": ".price, [data-price]",
        "subtitle_selector": ".offer-summary",
        "expiry_selector": ".expiry"
      },
      "manualDefaults": {
        "type": "monthly",
        "activation": 0,
        "promoMonths": 12,
        "constraintMonths": 12,
        "confidence": 55,
        "tags": ["selector", "review-required"]
      }
    }
  ]
